# Committed base configuration for local development.
# Use project-root .env only when you need machine-specific overrides.

# --- Application -----------------------------------------------
APP_NAME=UNIPLANE AI Platform
APP_ENV=development
DEBUG=true

# --- JWT Auth --------------------------------------------------
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- Database --------------------------------------------------
# Default to SQLite for easy local setup on any machine.
DATABASE_URL=sqlite:///./k8sai.db

# --- Redis (reserved for future wiring) ------------------------
REDIS_URL=redis://localhost:6379/0

# --- AI Providers ----------------------------------------------
AI_PROVIDER=auto
GENERAL_CHAT_PROVIDER=default
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com/chat/completions
GITHUB_MODELS_MODEL=openai/gpt-4.1-mini

# --- Kubernetes ------------------------------------------------
# Home-relative path works across machines when your kubeconfig is in the default location.
K8S_KUBECONFIG_PATHS=~/.kube/config
K8S_USE_IN_CLUSTER=false

# --- MCP -------------------------------------------------------
MCP_ENABLED=false
MCP_CLUSTER_ENDPOINTS=
MCP_TIMEOUT_SECONDS=10
MCP_GKE_KUBECONFIG_PATHS=
MCP_EKS_KUBECONFIG_PATHS=
MCP_AKS_KUBECONFIG_PATHS=
MCP_DATADOG_TARGETS=

# --- Vault -----------------------------------------------------
VAULT_URL=http://localhost:8200
VAULT_TOKEN=root

# --- Datadog ---------------------------------------------------
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# --- Safety guards ---------------------------------------------
PROD_MUTATION_REQUIRE_APPROVAL=true
MAX_MEMORY_LIMIT_GB=10