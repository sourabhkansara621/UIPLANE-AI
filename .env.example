# --- Application -----------------------------------------------
APP_NAME=UNIPLANE AI Platform
APP_ENV=development          # development | staging | production
DEBUG=true

# --- JWT Auth --------------------------------------------------
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- Database (Postgres) ---------------------------------------
DATABASE_URL=postgresql://k8sai:password@localhost:5432/k8sai_db

# --- Redis (session cache) -------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Anthropic (AI brain) --------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Kubernetes Clusters ---------------------------------------
# Comma-separated list of kubeconfig paths or in-cluster
K8S_KUBECONFIG_PATHS=/path/to/gke-prod.yaml,/path/to/eks-prod.yaml
K8S_USE_IN_CLUSTER=false

# --- HashiCorp Vault (secrets) ---------------------------------
VAULT_URL=http://localhost:8200
VAULT_TOKEN=root

# --- Datadog (Phase 5) -----------------------------------------
DATADOG_API_KEY=
DATADOG_APP_KEY=

# --- PROD mutation guard ---------------------------------------
PROD_MUTATION_REQUIRE_APPROVAL=true
MAX_MEMORY_LIMIT_GB=10
